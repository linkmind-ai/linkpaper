APP_NAME="LinkPaper API"
ENVIRONMENT="local"
API_PREFIX="/api/v1"
LOG_LEVEL="INFO"

# 외부 서비스 어댑터를 구현할 때 사용할 연결 정보
OPENAI_API_KEY=""
NEO4J_URI="bolt://neo4j:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="linkpaper-password"
POSTGRES_DB="linkpaper"
POSTGRES_USER="linkpaper"
POSTGRES_PASSWORD="linkpaper-password"
DATABASE_URL="postgresql://linkpaper:linkpaper-password@postgres:5432/linkpaper"

# 로컬 Docker Compose 포트
BACKEND_PORT="8000"
NEO4J_HTTP_PORT="7474"
NEO4J_BOLT_PORT="7687"
POSTGRES_PORT="5432"
